{
  "name": "@joinclass/axiom-ui",
  "version": "0.1.0",
  "description": "Copy-and-own React UI components designed for LLMs as the primary consumer. Ships a CLI and an MCP server.",
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "typescript",
    "llm",
    "ai-first",
    "mcp",
    "shadcn"
  ],
  "homepage": "https://github.com/JOINCLASS/axiom-ui",
  "bugs": "https://github.com/JOINCLASS/axiom-ui/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/JOINCLASS/axiom-ui.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "axiom-ui": "dist/cli/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "manifests.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite playground --config vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "gate": "node --experimental-strip-types scripts/measure.ts",
    "eval": "node --experimental-strip-types evals/run.ts",
    "deletion-ratio": "sh scripts/deletion-ratio.sh",
    "build": "node --experimental-strip-types scripts/build.ts",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm gate && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gpt-tokenizer": "^3.4.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
